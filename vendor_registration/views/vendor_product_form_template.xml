<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="vendor_product_form"
              name="Vendor Product Registration Form">

        <t t-call="portal.portal_layout">

            <t t-set="breadcrumbs_searchbar"
               t-value="True"/>

            <t t-call="portal.portal_searchbar">

                <t t-set="title">
                    Register Products &amp; Services
                </t>

            </t>

            <div class="container py-4">

                <!-- Success -->
                <t t-if="request.params.get('success')">

                    <div class="alert alert-success">

                        <i class="fa fa-check-circle me-2"/>

                        Your product / service has been submitted successfully
                        and is under review.

                    </div>

                </t>

                <!-- Error -->
                <t t-if="request.params.get('error')">

                    <div class="alert alert-danger">

                        <i class="fa fa-exclamation-triangle me-2"/>

                        <t t-esc="request.params.get('error')"/>

                    </div>

                </t>

                <!-- Submit Form -->
                <div class="card mb-5 shadow-sm">

                    <div class="card-header bg-primary text-white fw-semibold">

                        <i class="fa fa-plus-circle me-2"/>

                        Submit a New Product / Service

                    </div>

                    <div class="card-body">

                        <form action="/my/vendor-products/submit"
                              method="post"
                              class="o_vendor_product_form">

                            <input type="hidden"
                                   name="csrf_token"
                                   t-att-value="request.csrf_token()"/>

                            <div class="row g-3">

                                <!-- Product Name -->
                                <div class="col-md-8 position-relative">

                                    <label class="form-label fw-semibold">

                                        Product / Service Name

                                        <span class="text-danger">*</span>

                                    </label>

                                    <input type="text"
                                           name="name"
                                           id="product-name-input"
                                           class="form-control"
                                           required="1"
                                           placeholder="e.g. Industrial Bearings – Type A"/>

                                    <input type="hidden"
                                           name="existing_product_tmpl_id"
                                           id="existing_product_tmpl_id"/>

                                    <div id="product-suggestions"
                                         class="list-group position-absolute mt-1 shadow-sm"
                                         style="z-index: 1050; display: none; width: min(100%, 640px);"/>

                                    <div id="product-match-info"
                                         class="form-text text-success"
                                         style="display: none;">
                                        Existing product selected.
                                        <button type="button"
                                                id="clear-product-match"
                                                class="btn btn-link btn-sm p-0 align-baseline">
                                            Clear
                                        </button>
                                    </div>

                                    <div id="product-new-info"
                                         class="form-text text-muted"
                                         style="display: none;">
                                        This will be submitted as a new product/service.
                                    </div>

                                </div>

                                <!-- Type -->
                                <div class="col-md-4">

                                    <label class="form-label fw-semibold">

                                        Type

                                        <span class="text-danger">*</span>

                                    </label>

                                    <select name="product_type"
                                            class="form-select"
                                            required="1">

                                        <option value="goods">
                                            Goods
                                        </option>

                                        <option value="service">
                                            Service
                                        </option>

                                    </select>

                                </div>

                                <!-- HSN -->
                                <div class="col-md-4 position-relative">

                                    <label class="form-label">
                                        HSN / SAC Code
                                    </label>

                                    <input type="text"
                                           name="l10n_in_hsn_code"
                                           id="hsn-code-input"
                                           class="form-control"
                                           placeholder="e.g. 84839000"/>

                                    <div id="hsn-suggestions"
                                         class="list-group position-absolute mt-1 shadow-sm"
                                         style="z-index: 1050; display: none; width: min(100%, 420px);"/>

                                </div>

                                <!-- Brand -->
                                <div class="col-md-4">

                                    <label class="form-label">
                                        Brand / Make
                                    </label>

                                    <input type="text"
                                           name="brand"
                                           class="form-control"/>

                                </div>

                                <!-- Model -->
                                <div class="col-md-4">

                                    <label class="form-label">
                                        Model / Part Number
                                    </label>

                                    <input type="text"
                                           name="model_number"
                                           class="form-control"/>

                                </div>

                                <!-- UOM -->
                                <div class="col-md-3">

                                    <label class="form-label">
                                        Unit of Measure
                                    </label>

                                    <input type="text"
                                           name="uom"
                                           class="form-control"
                                           placeholder="e.g. Nos, Kg, Ltr"/>

                                </div>

                                <!-- Price -->
                                <div class="col-md-3">

                                    <label class="form-label">
                                        Offered Price (₹)
                                    </label>

                                    <input type="number"
                                           name="price"
                                           class="form-control"
                                           min="0"
                                           step="0.01"
                                           value="0"/>

                                </div>

                                <!-- GST -->
                                <div class="col-md-3">

                                    <label class="form-label">
                                        GST %
                                    </label>

                                    <input type="number"
                                           name="tax_percent"
                                           class="form-control"
                                           min="0"
                                           step="0.01"
                                           value="18"/>

                                </div>

                                <!-- MOQ -->
                                <div class="col-md-3">

                                    <label class="form-label">
                                        Min. Order Qty
                                    </label>

                                    <input type="number"
                                           name="min_order_qty"
                                           class="form-control"
                                           min="1"
                                           step="1"
                                           value="1"/>

                                </div>

                                <!-- Lead Time -->
                                <div class="col-md-3">

                                    <label class="form-label">
                                        Lead Time (days)
                                    </label>

                                    <input type="number"
                                           name="lead_time"
                                           class="form-control"
                                           min="0"
                                           value="0"/>

                                </div>

                                <!-- Certifications -->
                                <div class="col-md-9">

                                    <label class="form-label">
                                        Certifications / Standards
                                    </label>

                                    <input type="text"
                                           name="certifications"
                                           class="form-control"
                                           placeholder="e.g. ISO 9001, BIS, CE"/>

                                </div>

                                <!-- Description -->
                                <div class="col-12">

                                    <label class="form-label">
                                        Description
                                    </label>

                                    <textarea name="description"
                                              class="form-control"
                                              rows="3"
                                              placeholder="Detailed product/service description, specifications..."/>

                                </div>

                            </div>

                            <!-- Submit -->
                            <div class="mt-3 text-end">

                                <button type="submit"
                                        class="btn btn-primary">

                                    <i class="fa fa-paper-plane me-2"/>

                                    Submit for Review

                                </button>

                            </div>

                        </form>

                    </div>

                </div>

                <!-- Bulk Upload -->
                <t t-if="allow_bulk_upload">
                <div class="card mb-5 shadow-sm border-0">

                    <div class="card-header bg-primary text-white">
                        <div class="fw-semibold">
                            <i class="fa fa-upload me-2"/>
                            Bulk Upload Products / Services
                        </div>
                        <div class="small opacity-75">
                            Upload goods or services from an Excel/CSV file.
                        </div>
                    </div>

                    <div class="card-body">

                        <div class="row g-3 align-items-end">
                            <div class="col-lg-5">
                                <label class="form-label fw-semibold mb-2">Templates</label>
                                <div class="d-flex flex-wrap gap-2">
                                    <a href="/my/vendor-products/template?type=goods"
                                       class="btn btn-outline-primary">
                                        <i class="fa fa-download me-2"/>
                                        Goods Template
                                    </a>
                                    <a href="/my/vendor-products/template?type=service"
                                       class="btn btn-outline-primary">
                                        <i class="fa fa-download me-2"/>
                                        Service Template
                                    </a>
                                    <a href="/my/vendor-products/template"
                                       class="btn btn-outline-secondary">
                                        <i class="fa fa-table me-2"/>
                                        Combined
                                    </a>
                                </div>
                            </div>

                            <form action="/my/vendor-products/bulk-upload"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="col-lg-7">

                                <input type="hidden"
                                       name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <label class="form-label fw-semibold mb-2">Upload File</label>
                                <div class="input-group">
                                    <input type="file"
                                           name="product_file"
                                           class="form-control"
                                           accept=".xlsx,.xls,.csv"
                                           required="1"/>

                                    <button type="submit"
                                            class="btn btn-primary">

                                        <i class="fa fa-paper-plane me-2"/>

                                        Submit Bulk Upload

                                    </button>
                                </div>

                            </form>

                        </div>

                    </div>

                </div>
                </t>

                <!-- Submitted Products -->
                <h5 class="mb-3 fw-bold">

                    Previously Submitted Products &amp; Services

                </h5>

                <t t-if="not submitted_products">

                    <div class="alert alert-info">

                        You have not submitted any products or services yet.

                    </div>

                </t>

                <t t-if="submitted_products">

                    <div class="table-responsive">

                        <table class="table table-bordered table-hover">

                            <thead class="table-light">

                                <tr>

                                    <th>Name</th>

                                    <th>Type</th>

                                    <th>HSN / SAC</th>

                                    <th>Price (₹)</th>

                                    <th>Submitted On</th>

                                    <th>Status</th>

                                </tr>

                            </thead>

                            <tbody>

                                <t t-foreach="submitted_products"
                                   t-as="prod">

                                    <tr>

                                        <td>
                                            <t t-esc="prod.name"/>
                                        </td>

                                        <td>
                                            <t t-esc="prod._get_product_type_label()"/>
                                        </td>

                                        <td>
                                            <t t-esc="prod.l10n_in_hsn_code or '—'"/>
                                        </td>

                                        <td>
                                            <t t-esc="'%.2f' % prod.price"/>
                                        </td>

                                        <td>
                                            <t t-esc="prod.create_date.strftime('%d %b %Y')"/>
                                        </td>

                                        <td>

                                            <t t-if="prod.state == 'draft'">

                                                <span class="badge bg-warning text-dark">
                                                    Under Review
                                                </span>

                                            </t>

                                            <t t-elif="prod.state in ['approved', 'merged']">

                                                <span class="badge bg-success">
                                                    Approved
                                                </span>

                                            </t>

                                            <t t-elif="prod.state == 'rejected'">

                                                <span class="badge bg-danger">
                                                    Rejected
                                                </span>

                                            </t>

                                        </td>

                                    </tr>

                                </t>

                            </tbody>

                        </table>

                    </div>

                </t>

            </div>

        </t>

    </template>

</odoo>
