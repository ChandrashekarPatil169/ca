<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
        Vendor Registration Form View (Odoo 19 Optimized)
    ========================================================== -->
    <record id="view_vendor_registration_form" model="ir.ui.view">
        <field name="name">vendor.registration.form</field>
        <field name="model">vendor.registration</field>
        <field name="arch" type="xml">

            <form string="Vendor Registration">

                <!-- ================= HEADER ================= -->
                <header>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn btn-primary"
                            invisible="state != 'draft'"
                            confirm="Approving will create a portal user and send login credentials to the vendor. Continue?"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn btn-danger"
                            invisible="state != 'draft'"/>

                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state == 'draft'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,approved,rejected"/>

                </header>

                <!-- ================= SHEET ================= -->
                <sheet>

                    <!-- ================= SMART BUTTONS ================= -->
                    <div class="oe_button_box" name="button_box">

                        <button name="action_open_partner"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                invisible="not partner_id">

                            <field name="partner_id"
                                   widget="statinfo"
                                   string="Contact"/>
                        </button>

                        <button name="action_open_product_requests"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cubes"
                                invisible="state != 'approved'">

                            <field name="product_request_count"
                                   widget="statinfo"
                                   string="Products"/>
                        </button>

                    </div>

                    <!-- ================= TITLE ================= -->
                    <div class="oe_title">

                        <label for="name"/>

                        <h1>
                            <field name="name"
                                   placeholder="Company / Vendor Name"/>
                        </h1>

                    </div>

                    <!-- =================================================
                        MAIN INFORMATION
                    ================================================== -->
                    <group col="2">

                        <!-- Contact Information -->
                        <group string="Contact Information">

                            <field name="contact_name"/>
                            <field name="email" widget="email"/>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                            <field name="website" widget="url"/>

                        </group>

                        <!-- Business Details -->
                        <group string="Business Details">

                            <field name="company_type"/>
                            <field name="gst_number"/>
                            <field name="l10n_in_gst_treatment"/>
                            <field name="pan_number"/>
                            <field name="cin_number"/>
                            <field name="msme_number"/>
                            <field name="years_in_business"/>
                            <field name="annual_turnover"/>

                        </group>

                    </group>

                    <!-- =================================================
                        ADDRESS
                    ================================================== -->
                    <group string="Address" col="2">

                        <group>

                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                            <field name="zip"/>

                        </group>

                        <group>

                            <field name="state_id"
                                   options="{'no_open': True}"/>

                            <field name="country_id"
                                   options="{'no_open': True}"/>

                        </group>

                    </group>

                    <!-- =================================================
                        BANK DETAILS
                    ================================================== -->
                    <group string="Bank Details" col="2">

                        <group>

                            <field name="bank_name"/>
                            <field name="bank_account_number"/>

                        </group>

                        <group>

                            <field name="bank_ifsc"/>
                            <field name="bank_branch"/>

                        </group>

                    </group>

                    <!-- =================================================
                        APPROVAL INFORMATION
                    ================================================== -->
                    <group string="Approval Information"
                           invisible="state == 'draft'"
                           col="2">

                        <group>

                            <field name="partner_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>

                        </group>

                        <group>

                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>

                        </group>

                    </group>

                    <!-- Portal Permissions -->
                    <group string="Portal Permissions"
                           invisible="state != 'approved'">

                        <field name="allow_bulk_upload"
                               string="Allow Bulk Product Upload on Portal"
                               widget="boolean_toggle"
                               help="Uncheck to hide the Bulk Upload section from this vendor's portal page."/>

                    </group>

                    <!-- =================================================
                        NOTEBOOK
                    ================================================== -->
                    <notebook>

                        <page string="Notes">

                            <field name="notes"
                                   nolabel="1"
                                   placeholder="Additional notes or remarks..."/>

                        </page>

                    </notebook>

                </sheet>

                <!-- ================= CHATTER ================= -->
                <chatter/>

            </form>

        </field>
    </record>


    <!-- =========================================================
        Vendor Registration List View
    ========================================================== -->
    <record id="view_vendor_registration_list" model="ir.ui.view">
        <field name="name">vendor.registration.list</field>
        <field name="model">vendor.registration</field>
        <field name="arch" type="xml">

            <list decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-warning="state == 'draft'">

                <field name="name"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="company_type"/>
                <field name="gst_number"/>
                <field name="l10n_in_gst_treatment"/>
                <field name="city"/>
                <field name="state_id"/>
                <field name="create_date" string="Requested On"/>

                <field name="state"
                       widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-warning="state == 'draft'"/>

            </list>

        </field>
    </record>


    <!-- =========================================================
        Search View
    ========================================================== -->
    <record id="view_vendor_registration_search" model="ir.ui.view">
        <field name="name">vendor.registration.search</field>
        <field name="model">vendor.registration</field>
        <field name="arch" type="xml">

            <search>

                <field name="name"/>
                <field name="contact_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="gst_number"/>
                <field name="l10n_in_gst_treatment"/>

                <separator/>

                <filter string="Requested"
                        name="filter_draft"
                        domain="[('state','=','draft')]"/>

                <filter string="Approved"
                        name="filter_approved"
                        domain="[('state','=','approved')]"/>

                <filter string="Rejected"
                        name="filter_rejected"
                        domain="[('state','=','rejected')]"/>

                <separator/>

                <filter string="Status"
                        name="group_by_state"
                        context="{'group_by':'state'}"/>

                <filter string="Business Type"
                        name="group_by_company_type"
                        context="{'group_by':'company_type'}"/>

                <filter string="City"
                        name="group_by_city"
                        context="{'group_by':'city'}"/>

            </search>

        </field>
    </record>


    <!-- =========================================================
        Requested Vendors Action
    ========================================================== -->
    <record id="action_vendor_registration_requested"
            model="ir.actions.act_window">

        <field name="name">Requested Vendors</field>
        <field name="res_model">vendor.registration</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state','=','draft')]</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending vendor registration requests.
            </p>
        </field>

    </record>


    <!-- =========================================================
        All Vendor Registrations Action
    ========================================================== -->
    <record id="action_vendor_registration_all"
            model="ir.actions.act_window">

        <field name="name">All Vendor Registrations</field>
        <field name="res_model">vendor.registration</field>
        <field name="view_mode">list,form</field>

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No vendor registrations found.
            </p>
        </field>

    </record>


    <!-- ── res.partner form: add toggle in Sales & Purchase tab ── -->
    <record id="view_partner_allow_bulk_upload" model="ir.ui.view">
        <field name="name">res.partner.allow.bulk.upload</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Append to the Notes page which is always present in base -->
            <xpath expr="//notebook" position="inside">
                <page string="Vendor Portal" groups="purchase.group_purchase_user">
                    <group>
                        <field name="allow_bulk_upload"
                               string="Allow Bulk Product Upload on Portal"
                               widget="boolean_toggle"
                               help="Uncheck to hide the Bulk Upload section from this vendor's portal page."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


</odoo>
