<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_vendor_registration" model="ir.module.category">
        <field name="name">Vendor Registration</field>
    </record>

    <record id="vendor_registration_privilege" model="res.groups.privilege">
        <field name="name">Vendor Registration</field>
        <field name="category_id" ref="module_vendor_registration"/>
    </record>

    <record id="group_vendor_registration_manager" model="res.groups">
        <field name="name">Vendor Registration Manager</field>
        <field name="privilege_id" ref="vendor_registration_privilege"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
