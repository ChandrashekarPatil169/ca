<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_requisition_sale_order_form" model="ir.ui.view">
        <field name="name">product.requisition.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="before">
                <field name="allowed_vendor_ids" invisible="1" column_invisible="True"/>
            </xpath>

            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="before">
                <field name="allowed_vendor_ids" invisible="1"/>
            </xpath>
        </field>
    </record>

    <record id="product_requisition_product_template_ecommerce_categories" model="ir.ui.view">
        <field name="name">product.requisition.product.template.ecommerce.categories</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="public_categ_ids"
                       string="eCommerce Categories"
                       widget="many2many_tags"
                       invisible="not sale_ok"
                       placeholder="Add eCommerce categories"/>
            </xpath>
        </field>
    </record>

    <record id="product_requisition_product_variant_ecommerce_categories" model="ir.ui.view">
        <field name="name">product.requisition.product.variant.ecommerce.categories</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="public_categ_ids"
                       string="eCommerce Categories"
                       widget="many2many_tags"
                       invisible="not sale_ok"
                       placeholder="Add eCommerce categories"/>
            </xpath>
        </field>
    </record>

    <record id="product_requisition_crm_lead_form" model="ir.ui.view">
        <field name="name">product.requisition.crm.lead.form</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="dgz_crm_orderlines.dgz_crm_lead_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']//field[@name='order_line_ids']/list/field[@name='product_id']" position="after">
                <field name="product_status" readonly="1"/>
                <field name="product_category"/>
                <field name="asset_category_id"/>
            </xpath>
            <xpath expr="//page[@name='order_lines']//field[@name='order_line_ids']/list/field[@name='product_uom_qty']" position="after">
                <field name="uom_text"/>
                <field name="lead_time"/>
                <field name="budget"/>
                <field name="expected_date"/>
            </xpath>
        </field>
    </record>
</odoo>
